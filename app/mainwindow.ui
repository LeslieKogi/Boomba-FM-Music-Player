    <property name="styleSheet">
     <string notr="true">background-color: #0b0b12; /* Deep space black */
color: #ffffff;            /* Crisp white song text */
border: 1px solid #bd00ff; /* Sharp Neon Purple frame */
border-radius: 8px;
padding: 6px;

/* How a song looks when you hover your mouse over it */
QListWidget::item:hover {
    background-color: rgba(0, 255, 255, 0.12); /* Subtle neon blue glow */
    color: #00ffff;                            /* Turns text neon blue */
    border-radius: 4px;
}

/* How the currently selected/playing song looks */
QListWidget::item:selected {
    background-color: #00ffff; /* Bright Neon Blue selection bar */
    color: #000000;            /* Jet black text so it's clean and readable */
    font-weight: bold;
    border-radius: 4px;
}</string>
    </property>
