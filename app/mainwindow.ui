  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">/* The Main Background Gradient (Black, Neon Purple, Neon Blue) */
QWidget #centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #000000, 
                                stop:0.6 #25003e, 
                                stop:1 #002b47);
}

/* Make all text stand out in clean white */
QLabel {
    color: #ffffff;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* Style your buttons with Neon Purple borders and Neon Blue text */
QPushButton {
    background-color: rgba(255, 255, 255, 0.03);
    color: #00ffff; /* Electric Neon Blue */
    border: 1.5px solid #bd00ff; /* Sharp Neon Purple */
    border-radius: 6px;
    padding: 6px 12px;
    font-weight: bold;
}

/* Glowing effect when you hover over buttons */
QPushButton:hover {
    background-color: rgba(0, 255, 255, 0.08);
    border: 1.5px solid #00ffff; /* Flips to Neon Blue on hover */
}

/* The Music Progress Slider */
QSlider::groove:horizontal {
    height: 6px;
    background: #111122;
    border-radius: 3px;
}
QSlider::sub-page:horizontal {
    background: #00ffff; /* Neon Blue progress fill */
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #bd00ff; /* Neon Purple knob */
    width: 14px;
    margin-top: -4px;
    margin-bottom: -4px;
    border-radius: 7px;
}</string>
